@startuml
!include ../common/style.puml

skinparam rectangle {
  BorderColor #2B6CB0
  BorderThickness 2
  BackgroundColor #EBF8FF
  FontColor #1A365D
  FontSize 16
  FontStyle bold
}

left to right direction

actor Fournisseur #4ECDC4

rectangle "Plateforme B2B FMCG Export" {
  usecase (S'inscrire\nfournisseur) as UC_Register
  usecase (Se connecter) as UC_Login
  usecase (Completer\nfiche societe) as UC_Profile
  usecase (Soumettre\ndocuments legaux) as UC_LegalDocs
  usecase (Gerer\nproduits) as UC_ManageProducts
  usecase (Creer\nproduit) as UC_CreateProduct
  usecase (Modifier\nproduit) as UC_UpdateProduct
  usecase (Importer produits\nen masse) as UC_BulkImport
  usecase (Telecharger template\nd'import produit) as UC_Template
  usecase (Gerer caracteristiques\nproduit) as UC_Characteristics
  usecase (Ajouter images\nproduit) as UC_Images
  usecase (Gerer lots\net dates) as UC_Lots
  usecase (Gerer\nconditionnement) as UC_Packaging
  usecase (Mettre a jour\nstocks) as UC_Stocks
  usecase (Gerer grilles\ntarifaires) as UC_Pricing
  usecase (Consulter\nRFQ recues) as UC_ViewRFQ
  usecase (Repondre\nRFQ) as UC_ReplyRFQ
  usecase (Envoyer\nmessage) as UC_Message
  usecase (Consulter statistiques\nfournisseur) as UC_Stats
  usecase (Acheter\nsponsoring) as UC_Sponsoring
}

Fournisseur --> UC_Register
Fournisseur --> UC_Profile
Fournisseur --> UC_ManageProducts
Fournisseur --> UC_ViewRFQ
Fournisseur --> UC_Stats

UC_Register ..> UC_LegalDocs : <<include>>
UC_ManageProducts ..> UC_Login : <<include>>
UC_CreateProduct ..> UC_ManageProducts : <<include>>
UC_UpdateProduct ..> UC_ManageProducts : <<include>>
UC_BulkImport ..> UC_ManageProducts : <<include>>
UC_BulkImport ..> UC_Template : <<include>>
UC_BulkImport ..> UC_Characteristics : <<include>>
UC_Stocks ..> UC_ManageProducts : <<include>>
UC_Pricing ..> UC_ManageProducts : <<include>>
UC_ReplyRFQ ..> UC_ViewRFQ : <<include>>
UC_Lots ..> UC_ManageProducts : <<include>>
UC_Packaging ..> UC_ManageProducts : <<include>>

UC_Images ..> UC_ManageProducts : <<extend>>
UC_Message ..> UC_ReplyRFQ : <<extend>>
UC_Sponsoring ..> UC_Stats : <<extend>>

@enduml
